---
import '../styles/global.css';
import TzNav from '../components/TzNav.astro';
import TzFooter from '../components/TzFooter.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "titz.cooking",
  description = "Authentisch. Regional. Exzellent. Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,100..900,0..100,0..1;1,9..144,100..900,0..100,0..1&family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body class="tz-grain overflow-x-hidden">
    <TzNav />
    <main>
      <slot />
    </main>
    <TzFooter />
  </body>
</html>
