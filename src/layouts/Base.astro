---
import '../styles/global.css';
import TzNav from './TzNav.astro';
import TzFooter from './TzFooter.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "titz.cooking",
  description = "Authentisch. Regional. Exzellent. Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="bg-sand-50 text-sand-950 font-sans antialiased overflow-x-hidden">
    <TzNav />
    <main>
      <slot />
    </main>
    <TzFooter />
  </body>
</html>
