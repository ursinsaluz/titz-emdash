---
interface Props {
  className?: string;
}
const { className = "" } = Astro.props;
---
<div class={`flex items-baseline gap-4 group ${className}`}>
  <span class="tz-display italic text-2xl md:text-3xl tracking-tighter leading-none group-hover:text-[var(--ember)] transition-colors duration-500">titz.cooking</span>
  <span class="tz-mono text-[9px] text-[var(--ink-4)] uppercase tracking-[0.2em] hidden lg:inline">EST. MMXXIV</span>
</div>

