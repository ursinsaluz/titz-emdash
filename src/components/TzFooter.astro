---
import TzLogo from './TzLogo.astro';
import { getEmDashCollection, getMenu } from 'emdash';
import { Image } from 'emdash/ui';

const { entries: themeSettings } = await getEmDashCollection("theme_settings");
const config = themeSettings[0]?.data || {};

const footerMenu = await getMenu("footer");

const description = config.footer_description || "Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit. Schnörkellose Gerichte mit Wow-Effekt.";
const addressHTML = config.footer_address || "Sebastian Titz\nc/o Restaurant Pinot\n7306 Fläsch\n\n<a href=\"mailto:info@titz.cooking\" class=\"hover:text-[var(--ember)] transition-colors\">info@titz.cooking</a>";
const copyright = config.footer_copyright || "Sebastian Titz.";
const tagline = config.footer_tagline || "Handcrafted in Graubünden.";
---
<footer class="bg-[var(--paper)] text-[var(--ink)] py-32 px-6 md:px-12 border-t border-[var(--rule-soft)]">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-24">
    <div class="lg:col-span-6 flex flex-col gap-12">
      <TzLogo className="text-3xl" />
      <p class="text-[var(--ink-2)] text-balance leading-relaxed text-xl font-light max-w-md">
        {description}
      </p>
      <div class="flex items-center gap-8 tz-mono text-[10px] tracking-widest uppercase">
        <a href="https://instagram.com/sebastiantitz" target="_blank" class="hover:text-[var(--ember)] transition-colors">Instagram</a>
        <a href="https://linkedin.com" target="_blank" class="hover:text-[var(--ember)] transition-colors">LinkedIn</a>
      </div>
    </div>
    
    <div class="lg:col-span-3 flex flex-col gap-8">
      <h3 class="tz-mono text-[var(--ink-4)] text-[10px] tracking-[0.2em] uppercase">Navigation</h3>
      <div class="flex flex-col gap-4">
        {footerMenu?.items.map(item => (
          <a href={item.url} target={item.target} class="text-[var(--ink)] hover:text-[var(--ember)] transition-colors text-lg italic tz-display">
            {item.label}
          </a>
        ))}
        {!footerMenu?.items.length && (
          <p class="text-[var(--ink-4)] text-sm">Keine Navigation konfiguriert</p>
        )}
      </div>
    </div>
    
    <div class="lg:col-span-3 flex flex-col gap-8">
      <h3 class="tz-mono text-[var(--ink-4)] text-[10px] tracking-[0.2em] uppercase">Kontakt</h3>
      <address class="text-[var(--ink-2)] not-italic flex flex-col gap-4 text-sm leading-relaxed" set:html={addressHTML.replace(/\n/g, '<br/>')} />
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto mt-32 pt-12 border-t border-[var(--rule-soft)] flex flex-col md:flex-row justify-between items-center gap-8 text-[10px] text-[var(--ink-4)] tz-mono tracking-widest uppercase">
    <div class="flex gap-12">
      <p>&copy; {new Date().getFullYear()} {copyright}</p>
      <p>EST. MMXXIV</p>
    </div>
    <p>{tagline}</p>
  </div>
</footer>
