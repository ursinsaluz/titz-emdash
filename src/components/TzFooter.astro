---
import TzLogo from './TzLogo.astro';
---
<footer class="bg-forest-900 text-white py-24 md:py-32 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
    <div class="flex flex-col gap-6 lg:col-span-2 pr-0 lg:pr-24">
      <TzLogo className="text-white" />
      <p class="text-sand-300 text-balance leading-relaxed text-lg">
        Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit. 
        Schnörkellose Gerichte mit Wow-Effekt.
      </p>
    </div>
    
    <div class="flex flex-col gap-4">
      <h3 class="font-medium text-lg mb-2">Navigation</h3>
      <a href="/" class="text-sand-300 hover:text-white transition-colors">Start</a>
      <a href="/stationen" class="text-sand-300 hover:text-white transition-colors">Stationen</a>
      <a href="/impressum" class="text-sand-300 hover:text-white transition-colors">Impressum</a>
      <a href="/datenschutz" class="text-sand-300 hover:text-white transition-colors">Datenschutz</a>
    </div>
    
    <div class="flex flex-col gap-4">
      <h3 class="font-medium text-lg mb-2">Kontakt</h3>
      <address class="text-sand-300 not-italic flex flex-col gap-2">
        <p>Sebastian Titz</p>
        <p>c/o Restaurant Pinot</p>
        <p>7306 Fläsch</p>
        <p class="mt-4">
          <a href="mailto:info@titz.cooking" class="hover:text-white transition-colors">info@titz.cooking</a>
        </p>
      </address>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto mt-24 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-sand-300">
    <p>&copy; {new Date().getFullYear()} Sebastian Titz.</p>
    <p>Handcrafted in Graubünden.</p>
  </div>
</footer>
