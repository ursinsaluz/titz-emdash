---
import TzLogo from './TzLogo.astro';
import { getEmDashCollection, getMenu } from 'emdash';
import { Image } from 'emdash/ui';

const { entries: themeSettings } = await getEmDashCollection("theme_settings");
const config = themeSettings[0]?.data || {};

const footerMenu = await getMenu("footer");

const description = config.footer_description || "Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit. Schnörkellose Gerichte mit Wow-Effekt.";
const addressHTML = config.footer_address || "Sebastian Titz\nc/o Restaurant Pinot\n7306 Fläsch\n\n<a href=\"mailto:info@titz.cooking\" class=\"hover:text-white transition-colors\">info@titz.cooking</a>";
const copyright = config.footer_copyright || "Sebastian Titz.";
const tagline = config.footer_tagline || "Handcrafted in Graubünden.";
---
<footer class="bg-sand-950 text-sand-50 py-24 md:py-32 px-6 md:px-12 border-t border-sand-900">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
    <div class="flex flex-col gap-8 lg:col-span-2 pr-0 lg:pr-24">
      {config.logo ? (
        <Image image={config.logo} class="h-8 w-auto object-contain grayscale invert brightness-200 opacity-90" />
      ) : (
        <TzLogo className="text-white opacity-90" />
      )}
      <p class="text-sand-400 text-balance leading-relaxed text-sm">
        {description}
      </p>
    </div>
    
    <div class="flex flex-col gap-5">
      <h3 class="font-mono text-xs font-semibold tracking-widest uppercase text-sand-500 mb-1">Navigation</h3>
      {footerMenu?.items.map(item => (
        <a href={item.url} target={item.target} class="text-sand-300 hover:text-white transition-colors text-sm">
          {item.label}
        </a>
      ))}
      {!footerMenu?.items.length && (
        <p class="text-sand-500 text-sm">Keine Navigation konfiguriert</p>
      )}
    </div>
    
    <div class="flex flex-col gap-5">
      <h3 class="font-mono text-xs font-semibold tracking-widest uppercase text-sand-500 mb-1">Kontakt</h3>
      <address class="text-sand-300 not-italic flex flex-col gap-1 text-sm leading-relaxed" set:html={addressHTML.replace(/\n/g, '<br/>')} />
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto mt-24 pt-8 border-t border-sand-800/50 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-sand-500 font-medium">
    <p>&copy; {new Date().getFullYear()} {copyright}</p>
    <p>{tagline}</p>
  </div>
</footer>
