---
import type { MediaValue, ContentBylineCredit } from "emdash";
import { Image } from "emdash/ui";

interface Props {
	title: string;
	excerpt?: string;
	featuredImage?: MediaValue | string;
	href: string;
	date?: Date;
	readingTime?: number;
	tags?: Array<{ slug: string; label: string }>;
	bylines?: ContentBylineCredit[];
}

const {
	title,
	excerpt,
	featuredImage,
	href,
	date,
	readingTime,
	tags,
	bylines,
} = Astro.props;

const formattedDate = date
	? date.toLocaleDateString("en-US", {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	: null;
---

<article class="group">
	<a href={href} class="block">
		<div class="aspect-[4/5] overflow-hidden rounded-sm mb-8 bg-[var(--paper-3)] relative">
			{
				featuredImage ? (
					<Image 
						image={featuredImage} 
						class="w-full h-full object-cover grayscale mix-blend-multiply opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000"
					/>
				) : (
					<div class="w-full h-full flex items-center justify-center p-8 text-center text-[var(--ink-4)] tz-mono text-[10px] tracking-widest italic border border-dashed border-[var(--rule)]">
						MOMENTAUFNAHME
					</div>
				)
			}
		</div>

		<div class="space-y-4">
			<div class="flex items-center gap-4">
				{formattedDate && (
					<time class="tz-mono text-[10px] text-[var(--ink-4)] uppercase tracking-widest">{formattedDate}</time>
				)}
				{readingTime && (
					<div class="flex items-center gap-4">
						<span class="w-1 h-1 rounded-full bg-[var(--ember)]"></span>
						<span class="tz-mono text-[10px] text-[var(--moss)] uppercase tracking-widest">{readingTime} min</span>
					</div>
				)}
			</div>
			
			<h2 class="tz-display text-2xl md:text-3xl group-hover:italic transition-all duration-300">{title}</h2>
			
			{excerpt && (
				<p class="text-[var(--ink-2)] text-sm font-light leading-relaxed line-clamp-2">{excerpt}</p>
			)}
		</div>
	</a>

	{
		tags && tags.length > 0 && (
			<div class="flex flex-wrap gap-2 mt-6">
				{tags.slice(0, 2).map((tag) => (
					<a href={`/tag/${tag.slug}`} class="tz-mono text-[9px] px-2 py-1 bg-[var(--paper-2)] border border-[var(--rule-soft)] uppercase tracking-widest text-[var(--ink-4)] hover:border-[var(--ember)] transition-colors">
						{tag.label}
					</a>
				))}
			</div>
		)
	}
</article>

