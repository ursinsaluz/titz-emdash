---
import TzLogo from './TzLogo.astro';
import { getEmDashCollection, getMenu } from 'emdash';
import { Image } from 'emdash/ui';

// Fetch global theme settings and primary menu
const { entries: themeSettings } = await getEmDashCollection("theme_settings");

interface ThemeSettings {
	site_name?: string;
	logo?: any;
	header_cta_text?: string;
	header_cta_url?: string;
}

const config = (themeSettings[0]?.data || {}) as ThemeSettings;

const primaryMenu = await getMenu("main");

const siteName: string = config.site_name || "titz.cooking";
const ctaText: string = config.header_cta_text || "Kontakt";
const ctaUrl: string = config.header_cta_url || "/#kontakt";

---

<nav
  id="tz-nav"
  class="fixed top-0 left-0 right-0 z-50 px-6 md:px-12 py-6 flex justify-between items-center bg-[var(--paper)]/95 backdrop-blur-sm border-b border-[var(--rule-soft)] transition-all duration-300"
  style="transition-timing-function: var(--ease-tz)"
>
  {/* Logo Left */}
  <div class="flex-1 flex justify-start">
    <a href="/" class="group" aria-label={siteName}>
      {config.logo ? (
        <Image image={config.logo} class="h-8 w-auto object-contain" />
      ) : (
        <TzLogo />
      )}
      {config.logo && <span class="sr-only">{siteName}</span>}
    </a>
  </div>

  {/* Desktop Nav Center */}
  <div class="hidden md:flex flex-[2] justify-center gap-12 items-center text-[13px] font-sans font-medium tracking-widest uppercase">
    {primaryMenu?.items.map(item => (
      <a 
        href={item.url} 
        target={item.target} 
        class="text-[var(--ink-2)] hover:text-[var(--ember)] transition-all duration-300 relative group py-1"
      >
        {item.label}
        <span class="absolute bottom-0 left-0 w-full h-[1px] bg-[var(--ember)] scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></span>
      </a>
    ))}
  </div>

  {/* CTA Right */}
  <div class="flex-1 flex justify-end">
    <a href={ctaUrl} class="tz-btn tz-btn-primary py-3 px-6 text-xs uppercase tracking-widest hidden md:inline-flex">
      {ctaText}
    </a>
    
    {/* Mobile Hamburger */}
    <button
      id="tz-menu-toggle"
      class="md:hidden flex flex-col gap-[5px] p-2 text-[var(--ink)] hover:text-[var(--ember)] transition-colors duration-300"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="tz-mobile-menu"
    >
      <span class="block w-6 h-[1px] bg-current transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-6 h-[1px] bg-current transition-all duration-300" id="bar2"></span>
    </button>
  </div>
</nav>

{/* Mobile Menu Overlay */}
<div
  id="tz-mobile-menu"
  class="fixed inset-0 z-40 bg-[var(--paper)] flex flex-col justify-center px-8 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  style="transition-timing-function: var(--ease-tz)"
>
  <div class="flex flex-col gap-8 mt-20">
    {primaryMenu?.items.map(item => (
      <a
        href={item.url}
        target={item.target}
        class="tz-display text-4xl text-[var(--ink)] hover:text-[var(--ember)] transition-colors duration-300 mobile-nav-link"
      >
        {item.label}
      </a>
    ))}
    <a href={ctaUrl} class="tz-btn tz-btn-ember w-fit mt-4 mobile-nav-link">
      {ctaText}
    </a>
  </div>

  <div class="mt-auto pb-12 border-t border-[var(--rule-soft)] pt-8">
    <span class="tz-eyebrow text-[var(--ink-4)]">{siteName}</span>
  </div>
</div>

<script>
  const toggle = document.getElementById('tz-menu-toggle');
  const menu = document.getElementById('tz-mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menu!.classList.remove('opacity-0', 'pointer-events-none');
    menu!.classList.add('opacity-100');
    toggle!.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    bar1!.style.transform = 'translateY(3.5px) rotate(45deg)';
    bar2!.style.transform = 'translateY(-3.5px) rotate(-45deg)';
  }

  function closeMenu() {
    isOpen = false;
    menu!.classList.add('opacity-0', 'pointer-events-none');
    menu!.classList.remove('opacity-100');
    toggle!.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    bar1!.style.transform = '';
    bar2!.style.transform = '';
  }

  toggle?.addEventListener('click', () => {
    if (isOpen) closeMenu(); else openMenu();
  });

  // Close when a nav link is clicked
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
