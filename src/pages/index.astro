---
import BaseLayout from '../layouts/Base.astro';
import TzArrow from '../components/TzArrow.astro';
import { getEntry } from 'astro:content';
import { getEmDashCollection } from 'emdash';
import { Image, PortableText } from 'emdash/ui';

// Define interfaces for type safety
interface EmDashEntry {
  id: string;
  data: any;
  edit: any;
  createdAt: string;
}

// Astro requires caching on pages that query EmDash
const { entries: dishes, cacheHint: dishesHint } = await getEmDashCollection("dishes");
const { entries: news, cacheHint: newsHint } = await getEmDashCollection("news");
const { entries: offers, cacheHint: offersHint } = await getEmDashCollection("offers");

// Combine cache hints
Astro.cache.set(dishesHint);

// Sort news by creation date
const sortedNews = (news as EmDashEntry[]).sort((a, b) => 
  new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()
);
const featuredOffers = offers.filter(o => o.data.featured);
---

<BaseLayout>
  {/* Hero Section */}
  <section class="min-h-screen pt-32 pb-24 px-6 md:px-12 flex flex-col justify-center bg-[var(--paper)] text-[var(--ink)] relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1600891964092-4316c288032e?auto=format&fit=crop&q=80&w=2000" 
        alt="Küche Atmosphäre" 
        class="w-full h-full object-cover opacity-10 mix-blend-multiply grayscale"
      />
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto w-full">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-12 mb-16">
        <div class="flex flex-col gap-6">
          <div class="flex items-center gap-4">
            <span class="tz-section-number">§ 01</span>
            <span class="tz-mono text-[var(--ink-4)]">EST. MMXXIV</span>
          </div>
          <h1 class="tz-display text-7xl md:text-[144px] lg:text-[180px] -ml-1 md:-ml-4 leading-[0.85] tracking-tight text-balance">
            Authentisch.<br/>
            <span class="italic text-[var(--ember)]">Regional.</span><br/>
            Exzellent.
          </h1>
        </div>
        
        <div class="max-w-xs flex flex-col gap-8">
          <p class="tz-mono text-[var(--ink-3)] leading-relaxed">
            46°59'N · 09°31'E<br/>
            FLÄSCH, GRAUBÜNDEN
          </p>
          <p class="text-xl text-[var(--ink-2)] font-light leading-relaxed">
            Kulinarik zwischen Michelin-Stern und Bündner Bodenständigkeit. 
            Schnörkellose Gerichte mit Wow-Effekt.
          </p>
          <div class="flex flex-col gap-4">
            <a href="#restaurant" class="tz-btn tz-btn-primary w-fit uppercase text-xs tracking-widest">
              Restaurant entdecken
            </a>
            <a href="/stationen" class="tz-link w-fit py-2 text-sm uppercase tracking-widest">
              Vita & Stationen
            </a>
          </div>
        </div>
      </div>
    </div>
    
    <div class="absolute bottom-12 left-6 md:left-12 tz-mono text-[var(--ink-4)] text-[10px] tracking-[0.3em] uppercase">
      Scroll to explore
    </div>
  </section>

  {/* Quote Section */}
  <section class="py-32 px-6 md:px-12 border-y border-[var(--rule-soft)]">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="tz-display text-4xl md:text-6xl italic text-[var(--ink-2)] leading-tight">
        "Das Produkt ist der Star. <br class="hidden md:block"/> Alles andere ist nur Handwerk."
      </h2>
    </div>
  </section>

  {/* Signature Dishes */}
  <section class="py-32 px-6 md:px-12 bg-[var(--paper)]">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-baseline gap-8 mb-24 border-b border-[var(--rule)] pb-12">
        <div class="flex items-center gap-6">
          <span class="tz-section-number">§ 02</span>
          <h2 class="tz-display text-5xl md:text-7xl">Signature Dishes</h2>
        </div>
        <p class="tz-mono text-[var(--ink-3)] max-w-sm">
          KLASSIKER, DIE BLEIBEN. PRODUKTFOKUS UND HANDWERKLICHE TIEFE.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-x-12 gap-y-24">
        {dishes.map((dish, i) => (
          <div class="group cursor-pointer flex flex-col">
            <a href={`/posts/${dish.id}`} class="group block relative">
              <div class="aspect-[2/3] overflow-hidden rounded-sm bg-[var(--paper-3)] mb-8">
                {dish.data.image && (
                  <Image 
                    image={dish.data.image} 
                    class="w-full h-full object-cover grayscale mix-blend-multiply opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000"
                    sizes="(min-width: 1024px) 25vw, (min-width: 768px) 50vw, 100vw"
                  />
                )}
                {/* Number Overlay */}
                <div class="absolute top-6 left-6 tz-mono text-[10px] text-[var(--paper)] mix-blend-difference opacity-40">
                  {String(i + 1).padStart(2, '0')}
                </div>
              </div>
              <div class="flex items-center justify-between gap-4 border-b border-[var(--rule-soft)] pb-4">
                <h3 class="tz-display text-2xl group-hover:italic transition-all duration-300" {...dish.edit.title}>{dish.data.title}</h3>
                <TzArrow className="w-5 h-5 text-[var(--ink-4)] group-hover:text-[var(--ember)] group-hover:translate-x-1 transition-all duration-300" />
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>


  {/* News */}
  <section class="py-32 px-6 md:px-12 bg-[var(--paper)]">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center gap-6 mb-24 border-b border-[var(--rule)] pb-12">
        <span class="tz-section-number">§ 03</span>
        <h2 class="tz-display text-5xl md:text-7xl">Aktuelles</h2>
      </div>
      
      <div class="flex flex-col divide-y divide-[var(--rule-soft)] border-y border-[var(--rule-soft)]">
        {sortedNews.map(item => (
          <article class="py-12 group cursor-pointer">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-12 items-start">
              <div class="md:col-span-3 tz-mono text-[var(--ink-4)] pt-2" {...item.edit.date}>
                {item.data.date}
              </div>
              <div class="md:col-span-8">
                <div class="flex items-center gap-3 mb-6">
                  <span class="tz-eyebrow text-[var(--moss)]" {...item.edit.publication}>{item.data.publication}</span>
                  {item.data.tag && (
                    <>
                      <span class="w-1 h-1 rounded-full bg-[var(--ink-4)]"></span>
                      <span class="tz-eyebrow text-[var(--ink-4)]" {...item.edit.tag}>{item.data.tag}</span>
                    </>
                  )}
                </div>
                <h3 class="tz-display text-3xl md:text-4xl mb-6 group-hover:text-[var(--ember)] transition-colors" {...item.edit.title}>{item.data.title}</h3>
                <div class="text-[var(--ink-2)] leading-relaxed prose-sm max-w-2xl" {...item.edit.body}>
                  <PortableText value={item.data.body} />
                </div>
              </div>
              <div class="hidden md:flex justify-end md:col-span-1 pt-2 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
                <TzArrow className="w-8 h-8 text-[var(--ember)]" />
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Offers */}
  <section id="angebote" class="py-32 px-6 md:px-12 bg-[var(--ink)] text-[var(--paper)]">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-baseline gap-8 mb-24 border-b border-white/10 pb-12">
        <div class="flex items-center gap-6">
          <span class="tz-section-number text-white/40">§ 04</span>
          <h2 class="tz-display text-5xl md:text-7xl text-white">Angebote</h2>
        </div>
        <p class="tz-mono text-white/60 max-w-sm uppercase">
          KONZEPTBERATUNG & CATERING AUF HÖCHSTEM NIVEAU.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 lg:gap-32">
        <div class="flex flex-col gap-24">
          {offers.filter(o => !o.data.featured).map(offer => (
            <div class="group">
              <h3 class="tz-display text-4xl md:text-5xl mb-8 group-hover:italic transition-all duration-300" {...offer.edit.title}>{offer.data.title}</h3>
              <p class="text-[var(--paper-2)] text-xl font-light mb-6 leading-relaxed max-w-lg" {...offer.edit.lead}>{offer.data.lead}</p>
              <div class="text-[var(--paper-3)] mb-12 leading-relaxed prose-sm opacity-80 max-w-lg" {...offer.edit.body}>
                <PortableText value={offer.data.body} />
              </div>
              <a href="#kontakt" class="tz-btn tz-btn-primary w-fit uppercase text-xs tracking-widest" {...offer.edit.cta_text}>
                {offer.data.cta_text || 'Anfragen'}
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  {/* Kontakt Formular */}
  <section id="kontakt" class="py-32 px-6 md:px-12 bg-[var(--paper)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-24 items-start">
        <div class="lg:col-span-5">
          <div class="flex items-center gap-6 mb-12">
            <span class="tz-section-number">§ 05</span>
            <h2 class="tz-display text-5xl md:text-7xl">Kontakt</h2>
          </div>
          <p class="text-xl text-[var(--ink-2)] leading-relaxed mb-12 font-light">
            Haben Sie Fragen zu unseren Angeboten oder möchten Sie ein Projekt besprechen? 
            Wir freuen uns auf Ihre Nachricht.
          </p>
          <div class="space-y-4 tz-mono text-[var(--ink-3)]">
            <p>SEBASTIAN TITZ</p>
            <p>CH-7306 FLÄSCH</p>
            <p>INFO@TITZ.COOKING</p>
          </div>
        </div>

        <div class="lg:col-span-7 bg-[var(--paper-2)] p-8 md:p-16 rounded-sm border border-[var(--rule-soft)]">
          <form action="/api/contact" method="POST" class="space-y-12" id="contact-form">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
              <div class="border-b border-[var(--rule)] pb-2 focus-within:border-[var(--ember)] transition-colors">
                <label for="name" class="block tz-mono text-[10px] text-[var(--ink-4)] mb-4">NAME *</label>
                <input type="text" id="name" name="name" required
                  class="w-full bg-transparent focus:outline-none text-[var(--ink)] placeholder-[var(--ink-4)]/50"
                  placeholder="Max Mustermann"
                />
              </div>
              <div class="border-b border-[var(--rule)] pb-2 focus-within:border-[var(--ember)] transition-colors">
                <label for="email" class="block tz-mono text-[10px] text-[var(--ink-4)] mb-4">E-MAIL *</label>
                <input type="email" id="email" name="email" required
                  class="w-full bg-transparent focus:outline-none text-[var(--ink)] placeholder-[var(--ink-4)]/50"
                  placeholder="max@beispiel.ch"
                />
              </div>
            </div>

            <div class="border-b border-[var(--rule)] pb-2 focus-within:border-[var(--ember)] transition-colors">
              <label for="phone" class="block tz-mono text-[10px] text-[var(--ink-4)] mb-4">TELEFONNUMMER *</label>
              <input type="tel" id="phone" name="phone" required
                class="w-full bg-transparent focus:outline-none text-[var(--ink)] placeholder-[var(--ink-4)]/50"
                placeholder="+41 79 123 45 67"
              />
            </div>

            <div class="border-b border-[var(--rule)] pb-2 focus-within:border-[var(--ember)] transition-colors">
              <label for="message" class="block tz-mono text-[10px] text-[var(--ink-4)] mb-4">NACHRICHT (OPTIONAL)</label>
              <textarea id="message" name="message" rows="4"
                class="w-full bg-transparent focus:outline-none text-[var(--ink)] placeholder-[var(--ink-4)]/50 resize-none"
                placeholder="Wie können wir Ihnen helfen?"
              ></textarea>
            </div>

            <!-- Cloudflare Turnstile -->
            <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA'}></div>
            <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

            <div id="form-message" class="hidden p-4 rounded-sm text-sm"></div>

            <button type="submit" class="tz-btn tz-btn-primary w-full uppercase text-xs tracking-widest">
              Anfrage senden
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const formMessage = document.getElementById('form-message');

    if (form && formMessage) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalBtnText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = 'Wird gesendet...';
        
        formMessage.className = 'hidden p-4 rounded-md mb-6';
        
        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
          });
          
          const result = await response.json();
          
          if (response.ok) {
            formMessage.textContent = 'Vielen Dank für Ihre Anfrage. Wir melden uns umgehend bei Ihnen zurück.';
            formMessage.className = 'p-4 rounded-md mb-6';
            formMessage.style.cssText = 'background:var(--ember-soft);color:var(--ink);border:1px solid var(--ember)';
            form.reset();
            // Reset Turnstile if it exists globally
            if ((window as any).turnstile) {
              (window as any).turnstile.reset();
            }
          } else {
            throw new Error(result.error || 'Es ist ein Fehler aufgetreten.');
          }
        } catch (error) {
          formMessage.textContent = error instanceof Error ? error.message : 'Es ist ein Fehler aufgetreten. Bitte versuchen Sie es später erneut.';
          formMessage.className = 'p-4 rounded-md mb-6';
          formMessage.style.cssText = 'background:oklch(0.95 0.03 25);color:var(--ink);border:1px solid oklch(0.65 0.12 25)';
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalBtnText;
        }
      });
    }
  </script>
</BaseLayout>
