---
import Base from "../layouts/Base.astro";
---

<Base title="Seite nicht gefunden — titz.cooking">
  <section class="min-h-screen flex flex-col items-center justify-center px-6 text-center bg-[var(--paper)]">
    <span class="tz-display text-[12rem] leading-none text-[var(--paper-3)] select-none" aria-hidden="true">404</span>
    <h1 class="tz-display text-3xl md:text-5xl text-[var(--ink)] -mt-8 mb-6">Seite nicht gefunden</h1>
    <p class="text-lg text-[var(--ink-3)] max-w-md text-balance mb-12">
      Die gesuchte Seite existiert nicht oder wurde verschoben.
    </p>
    <div class="flex gap-4 flex-wrap justify-center">
      <a href="/" class="tz-btn tz-btn-primary">Zurück zur Startseite</a>
      <a href="/stationen" class="tz-btn tz-btn-ghost">Stationen</a>
    </div>
  </section>
</Base>
