---
import BaseLayout from '../layouts/Base.astro';
import TzArrow from '../components/TzArrow.astro';
import { getEmDashCollection } from 'emdash/runtime';
import { Image } from 'emdash/ui';

// Cache page
Astro.cache.set({ maxAge: 60, staleWhileRevalidate: 300 });

// Fetch data
const stations = await getEmDashCollection("stations");
const education = await getEmDashCollection("education");
const qualifications = await getEmDashCollection("qualifications");
const hobbies = await getEmDashCollection("hobbies");

// We sort them ascending by internal ID, or if we want specific order, 
// normally we'd add an `order` field. For now, rely on insertion order or sort by year descending.
// Simple sort by year parsing (first 4 digits)
const sortByYearDesc = (a, b) => {
  const yearA = parseInt(a.year?.match(/\d{4}/)?.[0] || "0");
  const yearB = parseInt(b.year?.match(/\d{4}/)?.[0] || "0");
  return yearB - yearA;
};

const sortedStations = stations.sort(sortByYearDesc);
const currentStation = sortedStations.find(s => s.current);
const pastStations = sortedStations.filter(s => !s.current);
---

<BaseLayout title="Stationen — titz.cooking">
  {/* Hero */}
  <section class="pt-40 pb-24 px-6 md:px-12 bg-sand-50">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex justify-center items-center gap-4 mb-8">
        <span class="w-8 h-[1px] bg-terracotta"></span>
        <span class="text-terracotta font-medium tracking-widest uppercase text-sm">Vita</span>
        <span class="w-8 h-[1px] bg-terracotta"></span>
      </div>
      <h1 class="text-5xl md:text-7xl font-medium tracking-tight mb-8">Stationen</h1>
      <p class="text-xl md:text-2xl text-sand-800 text-balance font-light leading-relaxed">
        Der Weg durch renommierte Küchen. Geprägt von herausragenden Mentoren, 
        anspruchsvollen Konzepten und der stetigen Suche nach dem eigenen Ausdruck.
      </p>
    </div>
  </section>

  {/* Current Station */}
  {currentStation && (
    <section class="py-12 px-6 md:px-12 bg-sand-50">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center bg-white p-6 md:p-12 rounded-sm shadow-sm border border-sand-100">
          <div class="order-2 lg:order-1">
            <div class="inline-block px-3 py-1 bg-forest-900 text-white text-xs font-medium uppercase tracking-widest mb-6">
              Aktuell
            </div>
            <h2 class="text-3xl md:text-4xl font-medium mb-2">{currentStation.title}</h2>
            <p class="text-sand-500 font-medium mb-6">{currentStation.place}</p>
            
            <div class="flex flex-col gap-4 mb-8">
              <div>
                <span class="block text-xs uppercase tracking-wider text-sand-500 mb-1">Position</span>
                <span class="font-medium text-lg">{currentStation.role}</span>
              </div>
              {currentStation.awards && (
                <div>
                  <span class="block text-xs uppercase tracking-wider text-sand-500 mb-1">Auszeichnungen</span>
                  <span class="font-medium text-terracotta">{currentStation.awards}</span>
                </div>
              )}
            </div>
            
            <p class="text-sand-800 leading-relaxed">{currentStation.body}</p>
          </div>
          
          <div class="order-1 lg:order-2 aspect-[4/3] rounded-sm overflow-hidden bg-sand-200">
            {currentStation.image && (
              <Image 
                image={currentStation.image} 
                class="w-full h-full object-cover"
                sizes="(min-width: 1024px) 50vw, 100vw"
              />
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Timeline */}
  <section class="py-24 md:py-32 px-6 md:px-12 bg-sand-50 relative">
    <div class="max-w-4xl mx-auto">
      <div class="relative border-l border-sand-300 pl-8 md:pl-12 ml-4 md:ml-0 space-y-20">
        {pastStations.map(station => (
          <div class="relative group">
            {/* Timeline Dot */}
            <div class="absolute -left-[41px] md:-left-[57px] top-1.5 w-4 h-4 rounded-full bg-sand-50 border-2 border-terracotta group-hover:bg-terracotta transition-colors"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
              <div class="md:col-span-3">
                <span class="text-terracotta font-medium tracking-wide">{station.year}</span>
              </div>
              <div class="md:col-span-9">
                <h3 class="text-2xl font-medium mb-1">{station.title}</h3>
                <p class="text-sand-500 mb-4">{station.place}</p>
                <div class="mb-4">
                  <span class="font-medium">{station.role}</span>
                  {station.awards && (
                    <span class="text-sand-600 block text-sm mt-1">{station.awards}</span>
                  )}
                </div>
                <p class="text-sand-800 leading-relaxed mb-6">{station.body}</p>
                
                {station.image && (
                  <div class="aspect-[16/9] overflow-hidden rounded-sm bg-sand-200 max-w-lg">
                    <Image 
                      image={station.image} 
                      class="w-full h-full object-cover"
                      sizes="(min-width: 768px) 50vw, 100vw"
                    />
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Education & Qualifications */}
  <section class="py-24 px-6 md:px-12 bg-sand-950 text-white">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-24">
      {/* Education */}
      <div>
        <h2 class="text-3xl font-medium tracking-tight mb-12 flex items-center gap-4">
          <span class="w-8 h-[1px] bg-terracotta"></span>
          Ausbildung
        </h2>
        <div class="flex flex-col gap-8">
          {education.map(item => (
            <div class="border-t border-white/10 pt-8">
              <span class="text-terracotta font-medium tracking-wide block mb-2">{item.year}</span>
              <h3 class="text-xl font-medium mb-1">{item.title}</h3>
              <p class="text-sand-400 mb-2">{item.place}</p>
              <p class="text-sm text-sand-500 leading-relaxed">{item.note}</p>
            </div>
          ))}
        </div>
      </div>
      
      {/* Qualifications */}
      <div>
        <h2 class="text-3xl font-medium tracking-tight mb-12 flex items-center gap-4">
          <span class="w-8 h-[1px] bg-terracotta"></span>
          Qualifikationen
        </h2>
        <div class="flex flex-col gap-8">
          {qualifications.map(item => (
            <div class="border-t border-white/10 pt-8">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs font-medium uppercase tracking-wider text-sand-400 bg-white/5 px-2 py-1 rounded-sm">
                  {item.kind}
                </span>
                {item.year !== '—' && (
                  <span class="text-terracotta font-medium tracking-wide">{item.year}</span>
                )}
              </div>
              <h3 class="text-xl font-medium mb-2">{item.title}</h3>
              <p class="text-sand-400 leading-relaxed text-sm">{item.note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Hobbies / Ausgleich */}
  <section class="py-24 md:py-32 px-6 md:px-12 bg-sand-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-medium tracking-tight mb-6">Ausgleich</h2>
        <p class="text-lg text-sand-600 max-w-2xl mx-auto text-balance">
          Was den Kopf frei macht und neue Inspiration liefert. 
          Die Natur als wichtigster Ausgleich zur intensiven Arbeit in der Küche.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {hobbies.map((hobby, i) => (
          <div class={`bg-white p-6 rounded-sm border border-sand-200 flex flex-col ${i === 0 ? 'lg:col-span-2 lg:row-span-2' : ''}`}>
            {hobby.image ? (
              <div class={`aspect-square overflow-hidden rounded-sm mb-6 bg-sand-100 ${i === 0 ? 'aspect-[4/3] lg:aspect-[16/9]' : ''}`}>
                <Image 
                  image={hobby.image} 
                  class="w-full h-full object-cover"
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                />
              </div>
            ) : hobby.placeholder ? (
              <div class={`aspect-square bg-sand-100 rounded-sm mb-6 flex items-center justify-center text-sand-400 text-sm italic border border-dashed border-sand-300 ${i === 0 ? 'aspect-[4/3] lg:aspect-[16/9]' : ''}`}>
                {hobby.placeholder}
              </div>
            ) : null}
            
            <h3 class="text-xl font-medium mb-3">{hobby.title}</h3>
            <p class="text-sand-600 text-sm leading-relaxed mt-auto">{hobby.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
