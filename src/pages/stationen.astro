---
import BaseLayout from '../layouts/Base.astro';
import TzArrow from '../components/TzArrow.astro';
import { getEmDashCollection } from 'emdash';
import { Image } from 'emdash/ui';

// Cache page
Astro.cache.set({ maxAge: 60, staleWhileRevalidate: 300 });

// Fetch data
const { entries: stations } = await getEmDashCollection("stations");
const { entries: education } = await getEmDashCollection("education");
const { entries: qualifications } = await getEmDashCollection("qualifications");
const { entries: hobbies } = await getEmDashCollection("hobbies");

// Simple sort by year parsing (first 4 digits)
const sortByYearDesc = (a, b) => {
  const yearA = parseInt(a.data.year?.match(/\d{4}/)?.[0] || "0");
  const yearB = parseInt(b.data.year?.match(/\d{4}/)?.[0] || "0");
  return yearB - yearA;
};

const sortedStations = stations.sort(sortByYearDesc);
const currentStation = sortedStations.find(s => s.data.current);
const pastStations = sortedStations.filter(s => !s.data.current);
---

<BaseLayout title="Stationen — titz.cooking">
  {/* Hero */}
  <section class="pt-40 pb-24 px-6 md:px-12 bg-[var(--paper)]">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex justify-center items-center gap-4 mb-8">
        <span class="w-8 h-[1px] bg-[var(--ember)]"></span>
        <span class="tz-eyebrow text-[var(--ember)]">Vita</span>
        <span class="w-8 h-[1px] bg-[var(--ember)]"></span>
      </div>
      <h1 class="tz-display text-5xl md:text-7xl mb-8">Stationen</h1>
      <p class="text-xl md:text-2xl text-[var(--ink-2)] text-balance font-light leading-relaxed">
        Der Weg durch renommierte Küchen. Geprägt von herausragenden Mentoren, 
        anspruchsvollen Konzepten und der stetigen Suche nach dem eigenen Ausdruck.
      </p>
    </div>
  </section>

  {/* Current Station */}
  {currentStation && (
    <section class="py-12 px-6 md:px-12 bg-[var(--paper)]">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center bg-[var(--paper-2)] p-6 md:p-12 rounded-md shadow-sm border border-[var(--rule-soft)]">
          <div class="order-2 lg:order-1">
            <div class="inline-block px-3 py-1 bg-[var(--moss)] text-[var(--paper)] tz-eyebrow mb-6">
              Aktuell
            </div>
            <h2 class="tz-display text-3xl md:text-4xl mb-2">{currentStation.data.title}</h2>
            <p class="text-[var(--ink-3)] font-medium mb-6">{currentStation.data.place}</p>
            
            <div class="flex flex-col gap-4 mb-8">
              <div>
                <span class="tz-eyebrow block text-[var(--ink-4)] mb-1">Position</span>
                <span class="font-medium text-lg text-[var(--ink)]">{currentStation.data.role}</span>
              </div>
              {currentStation.data.awards && (
                <div>
                  <span class="tz-eyebrow block text-[var(--ink-4)] mb-1">Auszeichnungen</span>
                  <span class="font-medium text-[var(--ember)]">{currentStation.data.awards}</span>
                </div>
              )}
            </div>
            
            <p class="text-[var(--ink-2)] leading-relaxed">{currentStation.data.body}</p>
          </div>
          
          <div class="order-1 lg:order-2 aspect-[4/3] rounded-md overflow-hidden bg-[var(--paper-3)]">
            {currentStation.data.image && (
              <Image 
                image={currentStation.data.image} 
                class="w-full h-full object-cover"
                sizes="(min-width: 1024px) 50vw, 100vw"
              />
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  {/* Timeline */}
  <section class="py-24 md:py-32 px-6 md:px-12 bg-[var(--paper)] relative">
    <div class="max-w-4xl mx-auto">
      <div class="relative border-l border-[var(--rule)] pl-8 md:pl-12 ml-4 md:ml-0 space-y-20">
        {pastStations.map(station => (
          <div class="relative group">
            {/* Timeline Dot */}
            <div class="absolute -left-[41px] md:-left-[57px] top-1.5 w-4 h-4 rounded-full bg-[var(--paper)] border-2 border-[var(--ember)] group-hover:bg-[var(--ember)] transition-colors duration-300" style="transition-timing-function: var(--ease-tz)"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
              <div class="md:col-span-3">
                <span class="text-[var(--ember)] font-medium tracking-wide">{station.data.year}</span>
              </div>
              <div class="md:col-span-9">
                <h3 class="tz-display text-2xl mb-1">{station.data.title}</h3>
                <p class="text-[var(--ink-3)] mb-4">{station.data.place}</p>
                <div class="mb-4">
                  <span class="font-medium text-[var(--ink)]">{station.data.role}</span>
                  {station.data.awards && (
                    <span class="text-[var(--ink-4)] block text-sm mt-1">{station.data.awards}</span>
                  )}
                </div>
                <p class="text-[var(--ink-2)] leading-relaxed mb-6">{station.data.body}</p>
                
                {station.data.image && (
                  <div class="aspect-[16/9] overflow-hidden rounded-md bg-[var(--paper-3)] max-w-lg">
                    <Image 
                      image={station.data.image} 
                      class="w-full h-full object-cover grayscale mix-blend-multiply opacity-80"
                      sizes="(min-width: 768px) 50vw, 100vw"
                    />
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Education & Qualifications */}
  <section class="py-24 px-6 md:px-12 bg-[var(--ink)] text-[var(--paper)]">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-24">
      {/* Education */}
      <div>
        <h2 class="tz-display text-3xl tracking-tight mb-12 flex items-center gap-4">
          <span class="w-8 h-[1px] bg-[var(--ember)]"></span>
          Ausbildung
        </h2>
        <div class="flex flex-col gap-8">
          {education.map(item => (
            <div class="border-t border-[var(--ink-3)] pt-8">
              <span class="text-[var(--ember)] font-medium tracking-wide block mb-2">{item.data.year}</span>
              <h3 class="tz-display text-xl mb-1">{item.data.title}</h3>
              <p class="text-[var(--paper-2)] mb-2">{item.data.place}</p>
              <p class="text-sm text-[var(--paper-3)] leading-relaxed">{item.data.note}</p>
            </div>
          ))}
        </div>
      </div>
      
      {/* Qualifications */}
      <div>
        <h2 class="tz-display text-3xl tracking-tight mb-12 flex items-center gap-4">
          <span class="w-8 h-[1px] bg-[var(--ember)]"></span>
          Qualifikationen
        </h2>
        <div class="flex flex-col gap-8">
          {qualifications.map(item => (
            <div class="border-t border-[var(--ink-3)] pt-8">
              <div class="flex items-center gap-3 mb-2">
                <span class="tz-eyebrow text-[var(--paper-3)] bg-white/5 px-2 py-1 rounded-sm">
                  {item.data.kind}
                </span>
                {item.data.year !== '—' && (
                  <span class="text-[var(--ember)] font-medium tracking-wide">{item.data.year}</span>
                )}
              </div>
              <h3 class="tz-display text-xl mb-2">{item.data.title}</h3>
              <p class="text-[var(--paper-3)] leading-relaxed text-sm">{item.data.note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Hobbies / Ausgleich */}
  <section class="py-24 md:py-32 px-6 md:px-12 bg-[var(--paper-2)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="tz-display text-3xl md:text-5xl mb-6">Ausgleich</h2>
        <p class="text-lg text-[var(--ink-3)] max-w-2xl mx-auto text-balance">
          Was den Kopf frei macht und neue Inspiration liefert. 
          Die Natur als wichtigster Ausgleich zur intensiven Arbeit in der Küche.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {hobbies.map((hobby, i) => (
          <div class={`bg-[var(--paper)] p-6 rounded-md border border-[var(--rule-soft)] flex flex-col ${i === 0 ? 'lg:col-span-2 lg:row-span-2' : ''}`}>
            {hobby.data.image ? (
              <div class={`aspect-square overflow-hidden rounded-md mb-6 bg-[var(--paper-3)] ${i === 0 ? 'aspect-[4/3] lg:aspect-[16/9]' : ''}`}>
                <Image 
                  image={hobby.data.image} 
                  class="w-full h-full object-cover"
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                />
              </div>
            ) : hobby.data.placeholder ? (
              <div class={`aspect-square bg-[var(--paper-3)] rounded-md mb-6 flex items-center justify-center text-[var(--ink-4)] text-sm italic border border-dashed border-[var(--ink-4)] ${i === 0 ? 'aspect-[4/3] lg:aspect-[16/9]' : ''}`}>
                {hobby.data.placeholder}
              </div>
            ) : null}
            
            <h3 class="tz-display text-xl mb-3">{hobby.data.title}</h3>
            <p class="text-[var(--ink-2)] text-sm leading-relaxed mt-auto">{hobby.data.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
