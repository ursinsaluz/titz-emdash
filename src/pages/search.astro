---
export const prerender = false;

import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { getReadingTime, extractText } from "../utils/reading-time";

const query = Astro.url.searchParams.get("q")?.trim() || "";

const { entries: allPosts } = await getEmDashCollection("posts");

// Simple search: match query against title, excerpt, and content
function matchesQuery(post: (typeof allPosts)[0], q: string): boolean {
	if (!q) return false;
	const lower = q.toLowerCase();
	const title = (post.data.title || "").toLowerCase();
	const excerpt = (post.data.excerpt || "").toLowerCase();
	// Extract plain text from portable text blocks (avoids matching on _type, _key, etc.)
	const content = extractText(post.data.content).toLowerCase();
	return (
		title.includes(lower) || excerpt.includes(lower) || content.includes(lower)
	);
}

const results = query ? allPosts.filter((p) => matchesQuery(p, query)) : [];
---

<Base
	title={query ? `Search: ${query}` : "Search"}
	description="Search blog posts"
>
<Base
	title={query ? `Suche: ${query}` : "Suche"}
	description="Suche auf titz.cooking"
>
	<section class="pt-48 pb-32 px-6 md:px-12 bg-[var(--paper)]">
		<div class="max-w-7xl mx-auto">
			<div class="flex items-center gap-6 mb-24 border-b border-[var(--rule)] pb-12">
				<span class="tz-section-number">§ 07</span>
				<h1 class="tz-display text-5xl md:text-8xl">Suche</h1>
			</div>

			<div class="max-w-3xl">
				<form method="get" action="/search" class="flex gap-4 mb-16 border-b border-[var(--rule)] pb-4 focus-within:border-[var(--ember)] transition-colors">
					<input
						type="search"
						name="q"
						value={query}
						placeholder="Suchbegriff eingeben..."
						class="flex-1 bg-transparent focus:outline-none text-2xl font-light italic tz-display placeholder-[var(--ink-4)]/50"
						autofocus
					/>
					<button type="submit" class="tz-mono text-[10px] tracking-[0.2em] uppercase hover:text-[var(--ember)] transition-colors">Suchen</button>
				</form>

				{
					query && (
						<div class="mb-16">
							<p class="tz-mono text-[var(--ink-4)] text-[10px] tracking-[0.2em] uppercase mb-4">
								{results.length === 0
									? `Keine Treffer für "${query}"`
									: `${results.length} Ergebnis${results.length === 1 ? "" : "se"} für "${query}"`}
							</p>
							<span class="block tz-rule-soft"></span>
						</div>
					)
				}

				{
					results.length > 0 && (
						<div class="flex flex-col gap-12">
							{results.map((post) => (
								<a href={`/posts/${post.id}`} class="group border-b border-[var(--rule-soft)] pb-12 last:border-0 hover:border-[var(--ember)] transition-colors">
									<article>
										<div class="flex items-center gap-4 mb-4">
											<span class="tz-mono text-[10px] text-[var(--ink-4)] uppercase tracking-widest">{post.data.publishedAt}</span>
											<span class="w-1 h-1 rounded-full bg-[var(--ember)]"></span>
											<span class="tz-mono text-[10px] text-[var(--moss)] uppercase tracking-widest">{getReadingTime(post.data.content)}</span>
										</div>
										<h3 class="tz-display text-3xl md:text-4xl group-hover:italic transition-all duration-300">{post.data.title}</h3>
										<p class="text-[var(--ink-2)] mt-4 font-light leading-relaxed line-clamp-2 max-w-2xl">{post.data.excerpt}</p>
									</article>
								</a>
							))}
						</div>
					)
				}

				{!query && <p class="text-xl text-[var(--ink-3)] font-light italic tz-display">Bitte geben Sie einen Suchbegriff ein, um Beiträge zu finden.</p>}
			</div>
		</div>
	</section>
</Base>

