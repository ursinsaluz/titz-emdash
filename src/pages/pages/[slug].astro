---
import { getEmDashEntry, decodeSlug } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

Astro.cache.set(cacheHint);
---

<Base
	title={page.data.title}
	content={{ collection: "pages", id: page.data.id, slug }}
>
	<article class="pt-48 pb-32 px-6 md:px-12 bg-[var(--paper)]">
		<div class="max-w-4xl mx-auto">
			<header class="mb-24 border-b border-[var(--rule)] pb-12">
				<div class="flex items-center gap-6">
					<span class="tz-section-number">§ 08</span>
					<h1 class="tz-display text-5xl md:text-8xl" {...page.edit.title}>{page.data.title}</h1>
				</div>
			</header>

			<div class="prose-sm max-w-2xl font-light leading-relaxed text-lg" {...page.edit.content}>
				<PortableText value={page.data.content} />
			</div>
		</div>
	</article>
</Base>

